---
const { tittle } = Astro.props
---
<section>
    {tittle && <h2>{tittle}</h2>} 
    <slot />
</section>

<style>
    section {
    max-width: 700px;
    margin: 0 auto 48px;
  }

  h2 {
    margin-bottom: 8px;
    font-weight: 700;
    line-height: 1.5;
    font-size: 1.5rem;
  }

  @media (width <= 700px) {
    section {
      margin-bottom: 38px;
    }
  }

  @media print {
    section {
      max-width: 100%;
      margin-bottom: 20px;
    }

    h2 {
      font-size: 1.2rem;
      margin-bottom: 6px;
    }
  }
</style>