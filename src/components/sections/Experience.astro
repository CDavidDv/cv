---
import Section from '@/components/Section.astro'
import {work} from '@/cv.json'
---
<Section tittle="Experiencia laboral">
    <ul>
        {
            work.map(({name, startDate, endDate, position, summary, url}) =>{
                const startYear = new Date(startDate).getFullYear()
                const endYear = endDate != null ? new Date(endDate).getFullYear() : null
                const years = endYear != null ? `${startYear} - ${endYear}` : `${startYear}`

                return(
                    <li>
                        <article>
                            <header>
                                <div>
                                    <h3>{name}</h3>
                                    <h4>{position}</h4>
                                </div>

                                <time>{years}</time>
                            </header>
                            </article>
                            <footer>
                                <p>{summary}</p>
                            </footer>
                    </li>
                )
            })
        }
    </ul>
</Section>


<style>
    ul{
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    article h3{
        font-weight: 500;
        color: #111;
        font-size: 1rem;
        margin-bottom: 2px;
    }

    article h4{
        font-weight: 400;
        color: #222;
        font-size: 0.9rem;
    }

    header{
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 4px;
    }

    time{
        color: #555;
        font-size: 0.8rem;
        white-space: nowrap;
    }

    p {
        font-size: 0.85rem;
    }

    @media print {
        ul {
            gap: 12px;
        }
    }
</style>