---
import Section from '@/components/Section.astro'
import { skills } from '@/cv.json'
---
<Section tittle="Habilidades">
    <ul>
    {
        skills.map(({name}) =>{
            return(
                <li>
                    <span>{name}</span>
                </li>
            )
        })
    }
    </ul>
</Section>

<style>
    ul{
        display: inline-flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    li{
        border-radius: 4px;
        background-color: #f0f0f0;
        color: #333;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.25rem 0.5rem;
        border: 1px solid #e0e0e0;
    }

    @media print {
        ul {
            gap: 4px;
        }

        li {
            font-size: 0.7rem;
            padding: 0.2rem 0.4rem;
        }
    }
</style>