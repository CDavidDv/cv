---
import Section from '@/components/Section.astro'


import { projects } from '@/cv.json'
---
<Section tittle="Proyectos">
    <ul>
        {
            projects.map(({url, description, highlights, name, isActive}) => {
                return(
                    <li>
                        <article>
                            <header>
                                {
                                    url != null ?
                                    (<a href={url} title={`Ver el proyecyo en ${url}`}>
                                        <h3>{name}</h3>
                                    </a>) : (<h3>{name}</h3>)
                                }
                                <p>{description}</p>
                            </header>
                            <footer>
                                {highlights.map((highlight)=>{
                                    return(
                                        <span>{highlight}</span>
                                    )
                                })}
                            </footer>
                        </article>
                    </li>
                )
            })
        }
    </ul>
</Section>


<style>
    ul{
        display: grid;
        grid-template-columns: repeat(
            auto-fit,
            minmax(250px, 1fr)
        );
        gap: 12px;
    }

    article{
        border-radius: 6px;
        border: 1px solid #e8e8e8;
        gap: 12px;
        display: flex;
        flex-direction: column;
        padding: 12px;
        height: 100%;
    }

    article header{
        flex: 1;
    }

    footer{
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    footer span{
        border-radius: 4px;
        background-color: #f0f0f0;
        color: #444;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.15rem 0.5rem;
    }

    article h3{
        font-size: 0.95rem;
        margin-bottom: 4px;
        font-weight: 600;
    }

    article a{
        color: #111
    }

    article a:hover{
        text-decoration: underline;
    }

    article p{
        font-size: 0.8rem;
        line-height: 1.3;
        margin-bottom: 6px;
        color: #555;
    }

    @media print {
        ul {
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }

        article {
            padding: 10px;
            gap: 8px;
        }
    }
</style>